# Challenge #3
# Create a function that adds 2 numbers and if the result is odd,
# adds 1, then returns the result

def add_and_fix_odd(a, b):
  result = a + b
  if result % 2 != 0:
    result = result + 1
  return result

odd_answer = add_and_fix_odd(5, 2)
print("5 + 2 (fixed if odd) =", odd_answer)
