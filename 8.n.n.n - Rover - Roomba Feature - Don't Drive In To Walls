import RPi.GPIO as GPIO
import time

GPIO.setwarnings(False)
GPIO.setmode(GPIO.BCM)

# --------------------
# ULTRASONIC PINS
# --------------------
TRIG = 12
ECHO = 13
start = 0
# VCC = GPIO 4 (only if your kit really uses it as power)
VCC = 4

# --------------------
# MOTOR PINS
# --------------------
IN1 = 21
IN2 = 20
IN3 = 26
IN4 = 19

# --------------------
# SETUP
# --------------------
GPIO.setup(TRIG, GPIO.OUT)
GPIO.setup(ECHO, GPIO.IN)

GPIO.setup(VCC, GPIO.OUT)
GPIO.output(VCC, 1)   # power sensor ON

GPIO.setup(IN1, GPIO.OUT)
GPIO.setup(IN2, GPIO.OUT)
GPIO.setup(IN3, GPIO.OUT)
GPIO.setup(IN4, GPIO.OUT)

# --------------------
# MOTOR FUNCTIONS
# --------------------
def stop():
    GPIO.output(IN1, 0)
    GPIO.output(IN2, 0)
    GPIO.output(IN3, 0)
    GPIO.output(IN4, 0)
    print("STOP")

def forward():
    GPIO.output(IN1, 1)
    GPIO.output(IN2, 0)
    GPIO.output(IN3, 1)
    GPIO.output(IN4, 0)
    print("FORWARD")

def back():
    GPIO.output(IN1, 0)
    GPIO.output(IN2, 1)
    GPIO.output(IN3, 0)
    GPIO.output(IN4, 1)
    print("BACK")

def left():
    GPIO.output(IN1, 0)
    GPIO.output(IN2, 1)
    GPIO.output(IN3, 1)
    GPIO.output(IN4, 0)
    print("LEFT")

def right():
    GPIO.output(IN1, 1)
    GPIO.output(IN2, 0)
    GPIO.output(IN3, 0)
    GPIO.output(IN4, 1)
    print("RIGHT")

# --------------------
# DISTANCE FUNCTION
# --------------------
def get_distance():

    GPIO.output(TRIG, 0)
    time.sleep(0.05)

    GPIO.output(TRIG, 1)
    time.sleep(0.00001)
    GPIO.output(TRIG, 0)

    while GPIO.input(ECHO) == 0:
        start = time.time()

    while GPIO.input(ECHO) == 1:
        end = time.time()

    duration = end - start
    distance = duration * 17150
    return round(distance, 2)

# --------------------
# MAIN LOOP
# --------------------
stop()

while True:

    d = get_distance()
    print("Distance:", d)

    # OBSTACLE DETECTED
    if d < 15:
        stop()
        time.sleep(0.5)

        back()
        time.sleep(1)

        stop()
        time.sleep(0.3)

        right()
        time.sleep(0.8)

        stop()

    else:
        forward()
