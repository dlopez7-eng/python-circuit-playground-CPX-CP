def my_math(x, y, operation="add"):
  if operation == "add":
    result = x + y
    print("Addition:", x, "+", y, "=", result)
  elif operation == "subtract":
    result = x - y
    print("Subtraction:", x, "-", y, "=", result)
  elif operation == "multiply":
    result = x * y
    print("Multiplication:", x, "*", y, "=", result)
  elif operation == "divide":
    result = x / y
    print("Division:", x, "/", y, "=", result)
  else:
    result = x + y
    print("Default (Addition):", x, "+", y, "=", result)

  return result


def main():
  my_num_1 = 5
  my_num_2 = 2

  my_math(my_num_1, my_num_2)                 # Default (Addition)
  my_math(my_num_1, my_num_2, "subtract")
  my_math(my_num_1, my_num_2, "multiply")
  my_math(my_num_1, my_num_2, "divide")

main()





